{{!-- Product type --}}
{{#when _module.type }}
{{ "lib" }}
product:
  type: lib
  platforms: {{ _module.platforms }}
{{ else }}
product: {{ _module.type }}
{{/when}}

{{!-- Dependencies --}}
{{#each _module.dependencies.entries }}
{{#if isSinglePlatform}}dependencies:{{else}}dependencies{{#when key}}{{"common"}}{{else}}@{{key}}{{/when}}:{{/if}}
{{#each value}}
{{#when type}}
{{ "maven" }}
  - {{ group }}:{{ artifact }}:{{ version }}{{#if exported}}: exported{{/if}}
{{ "project" }}
  - {{ path }}{{#if exported}}: exported{{/if}}
{{ "catalog" }}
  - ${{ key }}{{#if exported}}: exported{{/if}}
{{/when}}
{{/each}}
{{/each}}

{{!-- Test dependencies --}}
{{#each _module.testDependencies.entries }}
{{#if isSinglePlatform}}test-dependencies:{{else}}test-dependencies{{#when key}}{{"common"}}{{else}}@{{key}}{{/when}}:{{/if}}
{{#each value}}
{{#when type}}
{{ "maven" }}
- {{ group }}:{{ artifact }}:{{ version }}
{{ "project" }}
- {{ path }}
{{ "catalog" }}
- ${{ key }}
{{/when}}
{{/each}}
{{/each}}
{{!-- Settings --}}
{{#if _module.amper}}
settings:
  {{#each _module.amper.entries}}
  {{#when key}}
  {{"kotlin"}}
  kotlin:
  {{#each value.entries}}
    {{ key }}: {{ value }}
  {{/each}}
  {{else}}
  {{ key }}: {{ value }}
  {{/when}}
  {{/each}}
{{/if}}
{{!-- Repositories --}}
{{#if isSingleModule}}
{{#if _project.gradle.repositories.size}}
repositories:
{{#each _project.gradle.repositories}}
  - id: {{id}}
    url: {{url}}
{{/each}}
{{/if}}
{{/if}}
